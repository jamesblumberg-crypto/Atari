   642 B45D			.proc clear_pmg
   643 = 7600			pmg_p0 = pmg + $200
   644 = 7680			pmg_p1 = pmg + $280
   645 = 7700			pmg_p2 = pmg + $300
   646 = 7780			pmg_p3 = pmg + $380
   647
   648 B45D A2 80			ldx #$80
   649 B45F A9 00			lda #0
   650 B461			loop
   651 B461 CA				dex
   652 B462 9D 00 76			sta pmg_p0,x
   653 B465 9D 80 76			sta pmg_p1,x
   654 B468 9D 00 77			sta pmg_p2,x
   655 B46B 9D 80 77			sta pmg_p3,x
   656 B46E 9D 80 75			sta pmg_missiles,x      ; Also clear missiles
   657 B471 D0 EE			bne loop
   658 B473 60				rts
   659 					.endp
