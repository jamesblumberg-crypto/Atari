    55 				.macro copy_data src dest num_pages
    56 				    mwa #:src tmp_addr1
    57 				    mwa #:dest tmp_addr2
    58 				
    59 				    ldy #0
    60 				    ldx #0
    61 				loop
    62 				    lda (tmp_addr1),y
    63 				    sta (tmp_addr2),y
    64 				    iny
    65 				    bne loop
    66 				    inc tmp_addr1 + 1
    67 				    inc tmp_addr2 + 1
    68 				    inx
    69 				    cpx #:num_pages
    70 				    bne loop
    71 				.endm
