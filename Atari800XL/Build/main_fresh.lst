   599 				* Proc: delay                             *
   600 				* Uses Real-time clock to delay x/60 secs *
   601 				* --------------------------------------- *
   602 B425			.proc delay (.byte x) .reg
   603 B425			start
   604 B425 A5 14			lda RTCLK2
   605 B427			wait
   606 B427 C5 14			cmp RTCLK2
   607 B429 F0 FC			beq wait
   608
   609 B42B CA				dex
   610 B42C D0 F7			bne start
   611
   612 B42E 60				rts
   613 					.endp
