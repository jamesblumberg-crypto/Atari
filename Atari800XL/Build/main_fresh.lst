   663 				* Load PMG Graphics                       *
   664 				* --------------------------------------- *
   665 B474			.proc load_pmg
   666 = 7600			pmg_p0 = pmg + $200
   667 = 7680			pmg_p1 = pmg + $280
   668 = 7700			pmg_p2 = pmg + $300
   669 = 7780			pmg_p3 = pmg + $380
   670
   671 B474 A2 00			ldx #0
   672 B476			loop
   673 B476 BD 88 98 9D 3C 76		mva pmgdata,x pmg_p0+60,x
   674 B47C BD 90 98 9D BC 76		mva pmgdata+8,x pmg_p1+60,x
   675 B482 BD 98 98 9D 3C 77		mva pmgdata+16,x pmg_p2+60,x
   676 B488 BD A0 98 9D BC 77		mva pmgdata+24,x pmg_p3+60,x
   677 B48E E8				inx
   678 B48F E0 08			cpx #8
   679 B491 D0 E3			bne loop
   680 B493 60				rts
   681 					.endp
