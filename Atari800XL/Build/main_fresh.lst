   377 9C3C 85 98		    sta bitmap                  ; Save it back to the bitmap
   378 9C3E A5 B7		    lda room_row                ; Load the room row
   379 9C40 A8			    tay                         ; Set Y to the room row index
   380 9C41 A5 98		    lda bitmap                  ; Load the bitmap back into the accumulator
   381 9C43 91 BA		    sta (occupied_rooms_ptr),y  ; Store the bitmap into occupied room for appropriate index
   382 9C45			skip
   383 9C45 60			    rts
   384 				    .endp
