   391 9FDC A6 BD		    ldx tmp2
   392 9FDE 60			    rts
   393
   394 9FDF			contact_can_hit
   395 9FDF A9 78		    lda #120                    ; Increased from 48 to 120 frames (~2 seconds at 60fps)
   396 9FE1 8D 7E 73		    sta monster_contact_cooldown
   397
   398 9FE4 A5 98		    lda tmp                     ; Current monster tile ID (44-51)
   399 9FE6 38			    sec
   400 9FE7 E9 2C		    sbc #44                     ; Convert tile 44-51 to index 0-7
   401 9FE9 AA			    tax
   402 9FEA BD 2A 6D		    lda monster_dmg_table,x
   403 9FED 85 E5		    sta monster_dmg
   404
   405 				    ; Scale damage by floor depth.
   406 9FEF A5 D8		    lda dungeon_floor
   407 9FF1 38			    sec
   408 9FF2 E9 01		    sbc #1
   409 9FF4 4A			    lsr
   410 9FF5 18			    clc
   411 9FF6 65 E5		    adc monster_dmg
   412 9FF8 85 E5		    sta monster_dmg
   413
   414 9FFA A5 E6		    lda player_hp
   415 9FFC 38			    sec
   416 9FFD E5 E5		    sbc monster_dmg
   417 9FFF 85 E6		    sta player_hp
   418 A001 A9 01		    lda #1
   419 A003 8D 7F 73		    sta player_hp_dirty
   420 A006 30 05		    bmi contact_player_dead
   421 A008 F0 03		    beq contact_player_dead
   422
   423 A00A A6 BD		    ldx tmp2
   424 A00C 60			    rts
   425
   426 A00D			contact_player_dead
   427 A00D A9 00		    lda #0
   428 A00F 85 E6		    sta player_hp
   429 A011 A9 01		    lda #1
   430 A013 8D 7F 73		    sta player_hp_dirty
   431 A016 A6 BD		    ldx tmp2
   432 A018 60			    rts
   433 				    .endp
   434
   435 				; Pick up a bow item at dir_ptr location
   436 A019			.proc pickup_bow
   437 				    ; Set has_bow flag
   438 A019 A9 01		    lda #1
   439 A01B 8D 72 73		    sta has_bow
   440
   441 				    ; Give the bow 10 damage (can be upgraded)
   442 A01E A9 12		    lda #18
   443 A020 8D 71 73		    sta player_ranged_dmg
   444
   445 				    ; Remove bow from map (replace with floor)
   446 A023 A0 00		    ldy #0
   447 A025 A9 7F		    lda #MAP_FLOOR
   448 A027 91 E0		    sta (dir_ptr),y
   449
   450 				    ; Update the ranged damage display on HUD
   451 A029 20 A4 B3		    jsr update_ranged_display
   452
   453 A02C 60			    rts
   454 				    .endp
   455
   456 				; Read keyboard for weapon switching
   457 				; Called from main game loop
   458 A02D			.proc read_keyboard
   459 A02D AD FC 02		    lda CH                      ; Read keyboard character code
   460 A030 C9 FF		    cmp #CH_NONE                ; No key pressed?
   461 A032 F0 22		    beq done                    ; Yes, exit
   462
   463 A034			check_bow_key
   464 A034 C9 15		    cmp #KEY_B                  ; 'B' key pressed?
   465 A036 D0 10		    bne check_melee_key         ; No, check next key
   466 A038 AD 72 73		    lda has_bow                 ; Do we have a bow?
   467 A03B F0 19		    beq done                    ; No bow, can't equip it
   468 A03D A9 01		    lda #1                      ; Yes, equip ranged weapon
   469 A03F 8D 73 73		    sta equipped_weapon
   470 A042 A9 FF		    lda #CH_NONE                ; Clear the key press
   471 A044 8D FC 02		    sta CH
   472 A047 60			    rts
   473
   474 A048			check_melee_key
   475 A048 C9 25		    cmp #KEY_M                  ; 'M' key pressed?
   476 A04A D0 0A		    bne done                    ; No, exit
   477 A04C A9 00		    lda #0                      ; Equip melee weapon
   478 A04E 8D 73 73		    sta equipped_weapon
   479 A051 A9 FF		    lda #CH_NONE                ; Clear the key press
   480 A053 8D FC 02		    sta CH
   481
   482 A056			done
   483 A056 60			    rts
   484 				    .endp
