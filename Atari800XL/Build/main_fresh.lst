    33 				; Get the direction from the joystick and update dir_ptr
    34 				; Does not support diagonal movement, and is processed in the following priority order: UP, DOWN, LEFT, RIGHT
    35 9DE9			.proc read_direction
    36 				    ; Temp vars used
    37 = 00BD			    stick_dir = tmp2            ; Current stick direction
    38 				    
    39 				    ; Init
    40 9DE9 A5 DE 85 E0 A5 DF +     mwa player_ptr dir_ptr      ; Copy the player pointer to the direction ptr as a base
    41 9DF1 AD 78 02 85 BD	    mva STICK0 stick_dir        ; Load stick bitmap from HW register
    42
    43 9DF6			check_up
    44 9DF6 29 01		    and #STICK_UP               ; Check to see if it's pushed UP
    45 9DF8 D0 11		    bne check_down              ; It's not pushed UP, so move to the next check
    46 9DFA 38 A5 E0 E9 8B 85 +     sbw dir_ptr #map_width      ; It is pushed UP, so move the temp pointer up one line
    47 9E05 A9 01		    lda #NORTH                  ; Track direction for arrow aiming
    48 9E07 8D 7A 73		    sta player_dir
    49 9E0A 60			    rts                         ; We're done updating the dir pointer (this will take priority)
    50
    51 9E0B			check_down
    52 9E0B A5 BD		    lda stick_dir               ; Re-copy non-mutated stick dir to A
    53 9E0D 29 02		    and #STICK_DOWN             ; Check to see if it's pushed DOWN
    54 9E0F D0 11		    bne check_left              ; It's not pushed DOWN, so move to the next check
    55 9E11 18 A5 E0 69 8B 85 +     adw dir_ptr #map_width      ; It is pushed DOWN, so move the temp pointer down one line
    56 9E1C A9 02		    lda #SOUTH                  ; Track direction for arrow aiming
    57 9E1E 8D 7A 73		    sta player_dir
    58 9E21 60			    rts
    59
    60 9E22			check_left
    61 9E22 A5 BD		    lda stick_dir               ; Re-copy non-mutated stick dir to AA
    62 9E24 29 04		    and #STICK_LEFT             ; Check to see if it's pushed LEFT
    63 9E26 D0 08		    bne check_right             ; It's not pushed LEFT, so move to the next check
    64 9E28 C6 E0		    dec dir_ptr                 ; It is pushed LEFT, so move the temp pointer left one
    65 9E2A A9 03		    lda #WEST                   ; Track direction for arrow aiming
    66 9E2C 8D 7A 73		    sta player_dir
    67 9E2F 60			    rts
    68
    69 9E30			check_right
    70 9E30 A5 BD		    lda stick_dir               ; Re-copy non-mutated stick dir to A
    71 9E32 29 08		    and #STICK_RIGHT            ; Check to see if it's pushed RIGHT
    72 9E34 D0 07		    bne done                    ; If not, we're done checking
    73 9E36 E6 E0		    inc dir_ptr                 ; It is pushed RIGHT, so move the temp pointer left one
    74 9E38 A9 04		    lda #EAST                   ; Track direction for arrow aiming
    75 9E3A 8D 7A 73		    sta player_dir
    76
    77 9E3D			done
    78 9E3D 60			    rts
    79 				    .endp
