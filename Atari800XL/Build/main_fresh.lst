  2045 				; Handle arrow hitting a monster
  2046 6F79			.proc arrow_hit_monster
  2047 6F79 A0 00		    ldy #0
  2048 6F7B B1 92		    lda (map_ptr),y
  2049 6F7D 85 E2		    sta tmp1
  2050
  2051 6F7F A5 E2		    lda tmp1
  2052 6F81 38			    sec
  2053 6F82 E9 2C		    sbc #44
  2054 6F84 AA			    tax
  2055
  2056 				    ; Compute scaled HP for this floor (same scaling as melee combat).
  2057 6F85 BD 22 6D		    lda monster_hp_table,x
  2058 6F88 85 E3		    sta monster_hp
  2059 6F8A A5 D8		    lda dungeon_floor
  2060 6F8C 38			    sec
  2061 6F8D E9 01		    sbc #1
  2062 6F8F 4A			    lsr
  2063 6F90 0A			    asl
  2064 6F91 0A			    asl
  2065 6F92 18			    clc
  2066 6F93 65 E3		    adc monster_hp
  2067 6F95 85 E3		    sta monster_hp
  2068
  2069 				    ; Middle-ground balance:
  2070 				    ; - Guaranteed kill if (ranged damage * 3) >= scaled monster HP
  2071 				    ; - Otherwise 25% chance to kill (lucky shot)
  2072 6F97 AD 71 73		    lda player_ranged_dmg
  2073 6F9A 85 BD		    sta tmp2
  2074 6F9C 0A			    asl
  2075 6F9D 18			    clc
  2076 6F9E 65 BD		    adc tmp2
  2077 6FA0 C5 E3		    cmp monster_hp
  2078 6FA2 B0 07		    bcs kill_monster
  2079
  2080 6FA4 20 37 BD		    jsr random16
  2081 6FA7 29 03		    and #3
  2082 6FA9 D0 14		    bne survived
  2083
  2084 6FAB			kill_monster
  2085 6FAB BD 32 6D		    lda monster_xp_table,x
  2086 6FAE 18			    clc
  2087 6FAF 65 E8		    adc player_xp
