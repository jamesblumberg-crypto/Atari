  1107 				; Fast map pointer calculation: map_ptr = map + tmp_y * 139 + tmp_x
  1108 				; Uses shift-and-add instead of looping. 139 = 128 + 8 + 2 + 1
  1109 BD7C			.proc fast_map_ptr
  1110 					; Start: tmp_addr2 = tmp_y (16-bit)
  1111 BD7C A5 AF			lda tmp_y
  1112 BD7E 85 A2			sta tmp_addr2
  1113 BD80 A9 00			lda #0
