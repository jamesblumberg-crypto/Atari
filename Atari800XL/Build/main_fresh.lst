    25 				.macro advance_ptr data ptr width count offset
    26 				    mwa :data :ptr
    27 				    lda :count  ; Check to make sure it's not 0
    28 				    beq done    ; If it is, we're done
    29 				
    30 				    ldy #0
    31 				loop
    32 				    adbw :ptr :width
    33 				    iny
    34 				    cpy :count
    35 				    bne loop
    36 				
    37 				done
    38 				    adbw :ptr :offset
    39 				.endm
