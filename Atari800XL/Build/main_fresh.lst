    41 				.macro copy_bytes src dest num_bytes
    42 				    mwa #:src tmp_addr1
    43 				    mwa #:dest tmp_addr2
    44 				
    45 				    ldy #0
    46 				loop
    47 				    lda (tmp_addr1),y
    48 				    sta (tmp_addr2),y
    49 				    iny
    50 				    cpy #:num_bytes
    51 				    bne loop
    52 				
    53 				.endm
