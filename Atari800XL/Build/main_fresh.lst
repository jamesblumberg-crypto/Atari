   472 				; Helper: Display a 3-digit number from A register at screen_ptr
   473 				; Destroys: A, X, Y, tmp, tmp2
   474 B3BE			.proc display_3_digits
   475 B3BE 85 98		    sta tmp                     ; Save value to convert
   476
   477 				    ; Calculate hundreds digit
   478 B3C0 A2 00		    ldx #0
   479 B3C2			hundreds_loop
   480 B3C2 C9 64		    cmp #100
   481 B3C4 90 07		    bcc tens
   482 B3C6 38			    sec
   483 B3C7 E9 64		    sbc #100
   484 B3C9 E8			    inx
   485 B3CA 4C C2 B3		    jmp hundreds_loop
   486
   487 B3CD			tens
   488 B3CD 85 BD		    sta tmp2                    ; Save remainder for tens
   489 B3CF 8A			    txa
   490 B3D0 18			    clc
   491 B3D1 69 2C		    adc #UI_NUMBER_0            ; Convert to UI character
   492 B3D3 A0 00		    ldy #0
   493 B3D5 91 94		    sta (screen_ptr),y          ; Display hundreds digit
   494
   495 				    ; Calculate tens digit
   496 B3D7 A5 BD		    lda tmp2
   497 B3D9 A2 00		    ldx #0
   498 B3DB			tens_loop
   499 B3DB C9 0A		    cmp #10
   500 B3DD 90 07		    bcc ones
   501 B3DF 38			    sec
   502 B3E0 E9 0A		    sbc #10
   503 B3E2 E8			    inx
   504 B3E3 4C DB B3		    jmp tens_loop
   505
   506 B3E6			ones
   507 B3E6 85 BD		    sta tmp2                    ; Save remainder for ones
   508 B3E8 8A			    txa
   509 B3E9 18			    clc
   510 B3EA 69 2C		    adc #UI_NUMBER_0            ; Convert to UI character
   511 B3EC A0 01		    ldy #1
   512 B3EE 91 94		    sta (screen_ptr),y          ; Display tens digit
   513
   514 				    ; Display ones digit
   515 B3F0 A5 BD		    lda tmp2
   516 B3F2 18			    clc
   517 B3F3 69 2C		    adc #UI_NUMBER_0            ; Convert to UI character
   518 B3F5 A0 02		    ldy #2
   519 B3F7 91 94		    sta (screen_ptr),y          ; Display ones digit
   520
   521 B3F9 60			    rts
   522 				.endp
