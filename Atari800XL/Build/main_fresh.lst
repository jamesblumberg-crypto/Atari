  1045 				; Uses a linear-feedback shift register (LFSR) to generate 8-bit pseudo-random numbers
  1046 				; More info: https://en.wikipedia.org/wiki/Linear-feedback_shift_register
  1047 				; Also here: https://forums.atariage.com/topic/159268-random-numbers/#comment-1958751
  1048 				; Also here: https://github.com/bbbradsmith/prng_6502
  1049 BD2D			.proc random8
  1050 BD2D A5 A7			lda rand				; Load in seed or last number generated
  1051 BD2F 4A				lsr						; Shift 1 place to the right
  1052 BD30 90 02			bcc no_eor				; Carry flag contains the last bit prior to shifting - if 0, skip XOR
  1053 BD32 49 B4			eor #$b4				; XOR with feedback value that produces a good sequence
  1054 BD34			no_eor
  1055 BD34 85 A7			sta rand				; Store the random number
  1056 BD36 60				rts
  1057 					.endp
  1058
  1059 BD37			.proc random16
  1060 BD37 A5 A7			lda rand				; Load in seed or last number generated
  1061 BD39 4A				lsr						; Shift 1 place to the right
  1062 BD3A 26 BE			rol rand16
  1063 BD3C 90 02			bcc no_eor				; Carry flag contains the last bit prior to shifting - if 0, skip XOR
  1064 BD3E 49 B4			eor #$b4				; XOR with feedback value that produces a good sequence
  1065 BD40			no_eor
  1066 BD40 85 A7			sta rand				; Store the random number
  1067 BD42 45 BE			eor rand16
  1068 BD44 60				rts
  1069 					.endp
