   363 9C25 29 07		    and #7                      ; Mask the last 3 bits as the column (mod 8)
   364 9C27 85 B6		    sta room_col                ; Store column to a temp variable
   365 9C29 A5 B7		    lda room_row
   366 9C2B 4A			    lsr                         ; Divide by 8 to get the row
   367 9C2C 4A			    lsr
   368 9C2D 4A			    lsr
   369 9C2E 85 B7		    sta room_row                ; Save into row
   370 9C30 A8			    tay                         ; Copy the room row to Y (index of occupied_rooms)
   371 9C31 B1 BA		    lda (occupied_rooms_ptr),y  ; Load in the correct byte for the row
   372 9C33 85 98		    sta bitmap
   373 9C35 A5 B6		    lda room_col                ; Load in the column
   374 9C37 A8			    tay                         ; Copy to Y register
   375 9C38 B1 B8		    lda (pow2_ptr),y            ; Get the power of 2 for the column
