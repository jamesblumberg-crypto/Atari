  1121
  1122 					; tmp_addr2 <<= 1 (×2)
  1123 BD8C 06 A2			asl tmp_addr2
  1124 BD8E 26 A3			rol tmp_addr2+1
  1125
  1126 					; map_ptr += tmp_addr2 (×1 + ×2 = ×3)
