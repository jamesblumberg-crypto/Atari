   524 				; Check if player has enough XP to level up
   525 				; If player_xp >= 90, level up:
   526 				;   - Increment player_level
   527 				;   - Reset player_xp (carry over excess)
   528 				;   - Restore player_hp to player_max_hp
   529 				;   - Increase player_melee_dmg by 25%
   530 				;   - Update HP and XP bars
   531 B3FA			.proc check_level_up
   532 B3FA A5 E8			lda player_xp
   533 B3FC C9 5A			cmp #90                    ; Check if XP >= 90
   534 B3FE 90 24			bcc no_level_up            ; If less than 90, no level up
   535
   536 B400			level_up
   537 					; Subtract 90 from XP (carry over excess)
   538 B400 A5 E8			lda player_xp
   539 B402 38				sec
   540 B403 E9 5A			sbc #90
   541 B405 85 E8			sta player_xp
   542
   543 					; Increment level
   544 B407 E6 E9			inc player_level
   545
   546 					; Restore HP to max
   547 B409 A5 E7			lda player_max_hp
   548 B40B 85 E6			sta player_hp
   549
   550 					; Increase damage by 25% (new_dmg = old_dmg + old_dmg/4)
   551 B40D A5 E4			lda player_melee_dmg
   552 B40F 85 98			sta tmp                    ; Save original damage
   553 B411 4A				lsr                        ; Divide by 2
   554 B412 4A				lsr                        ; Divide by 4 (now A = damage/4)
   555 B413 18				clc
   556 B414 65 98			adc tmp                    ; Add original damage (A = damage + damage/4 = 1.25 * damage)
   557 B416 85 E4			sta player_melee_dmg
   558
   559 					; Update all displays to reflect changes
   560 B418 20 A3 B2			jsr update_hp_bar
   561 B41B 20 0A B3			jsr update_xp_bar
   562 B41E 20 6E B3			jsr update_level_display
   563 B421 20 8B B3			jsr update_melee_display
   564
   565 B424			no_level_up
   566 B424 60				rts
   567 				.endp
