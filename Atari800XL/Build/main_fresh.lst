   303 				; Update the HP bar display based on current player HP
   304 				; HP bar has 6 segments, each represents roughly 1/6 of max HP
   305 				; Update the HP bar display based on current player HP
   306 B290 A9 00 85 94 A9 70 + 	mwa #screen screen_ptr
   307 B298 18 A5 94 69 1C 85 + 	adw screen_ptr #28          ; Position at start of HP bar (column offset for HP bar)
   308 				; Side effects: Modifies screen memory and temporary variables.
   309 B2A3			.proc update_hp_bar
   310 B2A3 A9 00 85 94 A9 70 + 	mwa #screen screen_ptr
   311 B2AB 18 A5 94 69 1C 85 + 	adw screen_ptr #28          ; Position at start of HP bar
   312
   313 					; Calculate number of full segments (~17 HP each for 100 HP max)
   314 B2B6 A5 E6			lda player_hp
   315 B2B8 18				clc
   316 					; Add a bias of 16 to achieve ceiling division, so 100 HP fills all 6 segments
   317 B2B9 69 10			adc #16                    ; Bias so 100 HP gives 6 segments (ceil division)
   318 B2BB A2 00			ldx #0                      ; X counts full segments
   319 B2BD			calc_segments
   320 B2BD C9 11			cmp #17                     ; Is HP >= 17?
   321 B2BF 90 08			bcc draw_bars               ; If less, start drawing
   322 B2C1 38				sec                         ; Always set carry before SBC
   323 B2C2 E9 11			sbc #17                     ; Subtract 17
   324 B2C4 E8				inx                         ; Increment segment counter
   325 B2C5 E0 06			cpx #6                      ; Max 6 segments
   326 B2C7 90 F4			bcc calc_segments
   327
   328 B2C9			draw_bars
   329 B2C9 86 98			stx tmp                     ; Save number of full segments
   330
   331 					; Draw left border
   332 B2CB A0 00			ldy #0
   333 B2CD A9 36			lda #UI_BAR_LEFT
   334 B2CF 91 94			sta (screen_ptr),y
   335 B2D1				inc16 screen_ptr
