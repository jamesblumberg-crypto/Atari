   427 				; Clear one door bit from avail_doors without arithmetic underflow.
   428 				; `sub #DOOR_*` corrupts the mask when the bit was already clear ($00-$08
   429 				; wraps to $F8+), which then poisons later walks via bogus high bits.
   430 				.macro clear_avail_bit bit
   431 				    lda (avail_doors_ptr),y
   432 				    and #($FF-:bit)
   433 				    sta (avail_doors_ptr),y
   434 				.endm
