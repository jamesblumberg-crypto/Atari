   328 9BFE			.proc get_room_occupied (.byte a) .reg
   329 = 0098			bitmap = tmp
   330 				    ; Treat out-of-range room indices as occupied so walks never leave 0-63.
   331 				    ; A bad index would otherwise read past occupied_rooms into weapon RAM.
   332 9BFE C9 40		    cmp #64
   333 9C00 90 03		    bcc in_range
   334 9C02 A9 01		    lda #1
   335 9C04 60			    rts
   336 9C05			in_range
   337 9C05 85 B7		    sta room_row
   338 9C07 29 07		    and #7                      ; Mask the last 3 bits as the column (mod 8)
   339 9C09 85 B6		    sta room_col                ; Store column to a temp variable
   340 9C0B A5 B7		    lda room_row
   341 9C0D 4A			    lsr                         ; Divide by 8 to get the row
   342 9C0E 4A			    lsr
   343 9C0F 4A			    lsr
   344 9C10 85 B7		    sta room_row                ; Store the room row
   345 9C12 A8			    tay                         ; Copy the room row to Y (index of occupied_rooms)
   346 9C13 B1 BA		    lda (occupied_rooms_ptr),y  ; Load in the correct byte for the row
   347 9C15 85 98		    sta bitmap                  ; Store bitmap
   348
   349 9C17 A5 B6		    lda room_col                ; Load in the column
   350 9C19 A8			    tay                         ; Copy to Y register
   351 9C1A B1 B8		    lda (pow2_ptr),y            ; Get the power of 2 for the column
   352 9C1C 25 98		    and bitmap                  ; AND with tmp to get the value of the bit position
   353 				    ; A contains the result
   354
   355 9C1E 60			    rts
   356 				    .endp
