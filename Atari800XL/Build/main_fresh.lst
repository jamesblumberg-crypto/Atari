  1136 BD9D 06 A2			asl tmp_addr2
  1137 BD9F 26 A3			rol tmp_addr2+1
  1138 BDA1 06 A2			asl tmp_addr2
  1139 BDA3 26 A3			rol tmp_addr2+1
  1140
  1141 					; map_ptr += tmp_addr2 (×3 + ×8 = ×11)
  1142 BDA5 A5 92			lda map_ptr
  1143 BDA7 18				clc
  1144 BDA8 65 A2			adc tmp_addr2
  1145 BDAA 85 92			sta map_ptr
  1146 BDAC A5 93			lda map_ptr+1
  1147 BDAE 65 A3			adc tmp_addr2+1
  1148 BDB0 85 93			sta map_ptr+1
  1149
  1150 					; tmp_addr2 <<= 4 (×128)
  1151 BDB2 06 A2			asl tmp_addr2
  1152 BDB4 26 A3			rol tmp_addr2+1
  1153 BDB6 06 A2			asl tmp_addr2
  1154 BDB8 26 A3			rol tmp_addr2+1
