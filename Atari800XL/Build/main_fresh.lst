  2091 6FB9 A0 00		    ldy #0
  2092 6FBB A9 7F		    lda #MAP_FLOOR
  2093 6FBD 91 92		    sta (map_ptr),y
  2094
  2095 6FBF			survived
  2096 6FBF 60			    rts
  2097 				    .endp
