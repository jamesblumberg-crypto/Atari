  1164 BDC7 85 92			sta map_ptr
  1165 BDC9 A5 93			lda map_ptr+1
  1166 BDCB 65 A3			adc tmp_addr2+1
  1167 BDCD 85 93			sta map_ptr+1
  1168
  1169 					; Add tmp_x
  1170 BDCF A5 92			lda map_ptr
  1171 BDD1 18				clc
  1172 BDD2 65 AE			adc tmp_x
  1173 BDD4 85 92			sta map_ptr
