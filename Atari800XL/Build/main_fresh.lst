   683 				* --------------------------------------- *
   684 				* Proc: setup_pmg                         *
   685 				* Sets up Player-Missile Graphics System  *
   686 				* --------------------------------------- *
   687 B494			.proc setup_pmg
   688 B494 A9 74 8D 07 D4		mva #>pmg PMBASE
   689 B499 A9 2E 8D 2F 02		mva #46 SDMCTL ; Single Line resolution
   690 B49E A9 03 8D 1D D0		mva #3 GRACTL  ; Enable PMG
   691 B4A3 A9 01 8D 6F 02		mva #1 GRPRIOR ; Give players priority
   692 B4A8 A9 00 8D 0C D0		mva #0 SIZEM         ; Normal width for all missiles (2 color clocks)
   693 B4AD A9 5C			lda #92
   694 B4AF 8D 00 D0			sta HPOSP0
   695 B4B2 8D 01 D0			sta HPOSP1
   696 B4B5 8D 02 D0			sta HPOSP2
   697 B4B8 8D 03 D0			sta HPOSP3
   698 B4BB 60				rts
   699 					.endp
   700
   701 				; fix_color - Adjusts tile color based on char_colors_ptr table
   702 				; Input: A = tile character value
   703 				; Output: A = adjusted tile character (possibly with bit 7 set for gold color)
   704 				; Preserves: Y register
   705 B4BC			.proc fix_color
   706 					; Save Y register
   707 B4BC 85 98			sta tmp
   708 B4BE 98				tya
   709 B4BF 48				pha
   710 B4C0 A5 98			lda tmp
   711
   712 					; Get number of LSRs to perform (how many times to shift)
   713 B4C2 29 07			and #$07
   714 B4C4 18 69 01			add #1
   715 B4C7 85 BD			sta tmp2
   716
   717 					; Get color index
   718 B4C9 A5 98			lda tmp
   719 B4CB 4A				lsr
   720 B4CC 4A				lsr
   721 B4CD 4A				lsr
   722 B4CE A8				tay
   723 B4CF B1 C5			lda (char_colors_ptr),y
   724
   725 					; Shift right as necessary to put the desired bit into the carry flag
   726 B4D1			shift_bits
   727 B4D1 4A				lsr
   728 B4D2 C6 BD			dec tmp2
   729 B4D4 D0 FB			bne shift_bits
   730
   731 					; Check the carry flag to see if it has a 1 - if so, it needs to be yellow, otherwise blue
   732 B4D6 90 07			bcc done
   733
   734 B4D8			add_color
   735 B4D8 A5 98			lda tmp
   736 B4DA 18 69 80			add #128
   737 B4DD 85 98			sta tmp
   738
   739 B4DF			done
   740 					; Restore the Y register
   741 B4DF 68				pla
   742 B4E0 A8				tay
   743 B4E1 A5 98			lda tmp
   744 B4E3 60				rts
   745 				.endp
   746
   747 				.macro blit_tile
   748 					lda (map_ptr),y			; Load the tile from the map
   749 					asl						; Multiply by two to get left character
   750 					jsr fix_color			; Apply color adjustment (now a procedure)
   751 					sta (screen_ptr),y		; Store the left character
   752 					inc16 screen_ptr		; Advance the screen pointer
   753 					lda (map_ptr),y
   754 					asl
   755 					add #1
   756 					jsr fix_color			; Apply color adjustment (now a procedure)
   757 					sta (screen_ptr),y		; Store the right character
   758 					adw map_ptr #1			; Advance the map pointer
