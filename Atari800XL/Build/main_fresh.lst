   615 				* --------------------------------------- *
   616 				* Proc: setup_colors                      *
   617 				* Sets up colors                          *
   618 				* --------------------------------------- *
   619 B42F			.proc setup_colors
   620 					; Character Set Colors
   621 B42F A9 0A 8D C4 02		mva #white COLOR0 	; %01
   622 B434 A9 32 8D C5 02		mva #red COLOR1  	; %10
   623 B439 A9 92 8D C6 02		mva #blue COLOR2	; %11
   624 B43E A9 2A 8D C7 02		mva #gold COLOR3    ; %11 (inverse)
   625 B443 A9 00 8D C8 02		mva #black COLOR4   ; %00
   626
   627 					; Player-Missile Colors
   628 					; P0=hair, P1=face, P2=body
   629 					; Arrow uses M2 which shares PCOLR2 with P2 (both will be red)
   630 B448 A9 00 8D C0 02		mva #black PCOLR0       ; Hair color (Player 0)
   631 B44D A9 2C 8D C1 02		mva #peach PCOLR1       ; Face color (Player 1)
   632 B452 A9 32 8D C2 02		mva #red PCOLR2         ; Body (P2) AND Arrow (M2) - both red
   633 B457 A9 00 8D C3 02		mva #black PCOLR3
   634
   635 B45C 60				rts
   636 					.endp
